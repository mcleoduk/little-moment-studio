{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "little-moment-studio.vercel.app"
        }
      ],
      "destination": "https://littlemomentstudio.co.uk/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.littlemomentstudio.co.uk"
        }
      ],
      "destination": "https://littlemomentstudio.co.uk/$1",
      "permanent": true
    }
  ]
}
